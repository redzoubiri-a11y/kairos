# Clé API ElevenLabs — OBLIGATOIRE.
# Copie ce fichier en ".env" puis colle ta clé ci-dessous.
# Récupère-la sur https://elevenlabs.io/ (Profile > API Keys).
ELEVENLABS_API_KEY=ta_cle_api_ici

# Voix à utiliser (optionnel). Par défaut : "Rachel".
# Liste des voix : https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Modèle TTS (optionnel). "eleven_multilingual_v2" gère bien le français.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
